<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Sign Up</title>
</head>
<body>
    <div id="container" style="max-width: 400px; margin-top: 100px;">
        <header><h1>Sign Up</h1></header>
        <% if (error) { %> <p style="color: #ff4d4d; margin-bottom: 10px;"><%= error %></p> <% } %>
        <form action="/signup" method="POST" id="search-form" style="display: flex; flex-direction: column; gap: 15px;">
            <input type="text" name="username" placeholder="Username" required>
            <input type="password" name="password" placeholder="Password" required>
            <button type="submit" class="more-info-btn" style="border:none; cursor:pointer;">Register</button>
        </form>
        <p style="margin-top: 20px;">Already have an account? <a href="/login" style="color:#1DB954; text-decoration:none; font-weight:bold;">Login</a></p>
    </div>
</body>
</html>