<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <title>Admin Control Panel</title>
</head>
<body class="admin-page">
    <div id="container">
        <header>
            <h1 class="admin-title">Admin Control Panel</h1>
            <div class="header-links">
                <a href="/" class="back-home">← Back to Home</a>
                <a href="/logout" class="logout-link">Logout</a>
            </div>
        </header>

        <div class="admin-flex-container">
            <div class="admin-card">
                <h3>Add New Album</h3>
                <form action="/admin/add-album" method="POST" enctype="multipart/form-data">
                    <input type="text" name="title" placeholder="Album Title" required>
                    
                    <select name="artist_id" required>
                        <option value="">Select Artist</option>
                        <% artists.forEach(artist => { %>
                            <option value="<%= artist.id %>"><%= artist.name %></option>
                        <% }) %>
                    </select>

                    <input type="number" name="release_year" placeholder="Year">
                    <textarea name="description" placeholder="Description..." rows="2"></textarea>

                    <div class="custom-upload">
                        <i data-lucide="image-plus"></i>
                        <span id="file-name">Click to upload cover</span>
                        <input type="file" name="album_image" accept="image/*" onchange="document.getElementById('file-name').innerText = this.files[0].name">
                    </div>

                    <button type="submit" class="btn-save">Save Album</button>
                </form>
            </div>

            <div class="admin-card">
                <h3>Add Artist</h3>
                <form action="/admin/add-artist" method="POST">
                    <input type="text" name="name" placeholder="Artist Name" required>
                    <div class="input-row">
                        <input type="text" name="genre" placeholder="Genre">
                        <input type="text" name="origin" placeholder="Origin">
                    </div>
                    <button type="submit" class="btn-secondary">Save Artist</button>
                </form>

                <hr class="divider">

                <h3>Add Song</h3>
                <form action="/admin/add-song" method="POST">
                    <select name="album_id" required>
                        <option value="">Select Album</option>
                        <% albums.forEach(album => { %>
                            <option value="<%= album.id %>"><%= album.title %></option>
                        <% }) %>
                    </select>
                    <input type="text" name="title" placeholder="Song Title" required>
                    <div class="input-row">
                        <input type="number" name="track_number" placeholder="Track #" min="1">
                        <input type="text" name="length" placeholder="Duration (4:20)">
                    </div>
                    <button type="submit" class="btn-secondary">Add Song</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>