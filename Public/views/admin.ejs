<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <title>Административен панел</title>
</head>
<body class="admin-page">
    <div id="container" style="max-width: 1200px; margin: 0 auto; padding: 20px;">
        <header class="home-header">
            <h1 class="admin-title">Административен панел</h1>
            <div class="filter-group">
                <a href="/" class="pill-btn">Начало</a>
                <a href="/logout" class="pill-btn logout-btn">Изход</a>
            </div>
        </header>

        <div class="admin-grid">
            
            <section class="admin-section main-form">
                <div class="admin-card-flat">
                    <h3 class="section-label">Добави албум</h3>
                    <form action="/admin/add-album" method="POST" enctype="multipart/form-data" class="auth-form">
                        <input type="text" name="title" class="auth-input" placeholder="Заглавие на албума" required>
                        
                        <div class="form-row">
                            <select name="artist_id" class="custom-select" required>
                                <option value="" hidden>Избери изпълнител</option>
                                <% artists.forEach(artist => { %>
                                    <option value="<%= artist.id %>"><%= artist.name %></option>
                                <% }) %>
                            </select>
                            <input type="number" name="release_year" class="auth-input" placeholder="Година" style="width: 120px; flex: none;">
                        </div>

                        <div class="form-row">
                            <select name="genre_id" id="genre-select" class="custom-select" required>
                                <option value="" hidden>Избери жанр</option>
                                <% genres.forEach(genre => { %>
                                    <option value="<%= genre.id %>"><%= genre.name %></option>
                                <% }) %>
                            </select>

                            <select name="subgenre_id" id="subgenre-select" class="custom-select" disabled>
                                <option value="" data-genre="none" disabled selected hidden>Избери поджанр</option>
                                <% subgenres.forEach(sub => { %>
                                    <option value="<%= sub.id %>" data-genre="<%= sub.genre_id %>"><%= sub.name %></option>
                                <% }) %>
                            </select>
                        </div>

                        <textarea name="description" class="auth-input admin-textarea" placeholder="Описание на албума..." rows="4"></textarea>

                        <div class="dropzone-wrapper">
                            <i data-lucide="image-plus"></i>
                            <p id="file-name">Качи обложка</p>
                            <input type="file" name="album_image" id="album_image" accept="image/*" required 
                                   onchange="document.getElementById('file-name').innerText = 'Избрано: ' + this.files[0].name">
                        </div>

                        <button type="submit" class="pill-btn admin-btn btn-full">Запази албума</button>
                    </form>
                </div>
            </section>

            <aside class="admin-sidebar">
                <div class="admin-card-flat">
                    <h3 class="section-label">ДОБАВИ ПЕСЕН</h3>
                    <form action="/admin/add-song" method="POST" enctype="multipart/form-data" class="auth-form">
                        <input type="text" name="title" class="auth-input" placeholder="Заглавие на песента" required>
                        
                        <div class="form-row">
                            <input type="number" name="track_number" class="auth-input" placeholder="№ песен" min="1">
                            <input type="text" name="length" class="auth-input" placeholder="Продължителност">
                        </div>

                        <select name="album_id" class="custom-select" required>
                            <option value="" hidden disabled selected>Избери албум</option>
                            <% albums.forEach(album => { %>
                                <option value="<%= album.id %>"><%= album.title %></option>
                            <% }) %>
                        </select>

                        <select name="artist_id" class="custom-select" required>
                            <option value="" hidden disabled selected>Избери изпълнител</option>
                            <% artists.forEach(artist => { %>
                                <option value="<%= artist.id %>"><%= artist.name %></option>
                            <% }) %>
                        </select>

                        <div class="dropzone-wrapper small-dz">
                            <i data-lucide="music"></i>
                            <p id="song-file-name">Качи MP3</p>
                            <input type="file" name="songFile" accept="audio/mpeg" 
                                onchange="document.getElementById('song-file-name').innerText = 'Избрано: ' + this.files[0].name">
                        </div>

                        <button type="submit" class="pill-btn admin-btn btn-full">Запази песента</button>
                    </form>
                </div>
            </aside>

            <section class="admin-full-width">
                <div class="admin-card-flat artist-card">
                    <h3 class="section-label">Добави изпълнител</h3>
                    <form action="/admin/add-artist" method="POST" enctype="multipart/form-data" class="auth-form">
                        
                        <div class="artist-input-group">
                            <div class="input-main">
                                <input type="text" name="name" class="auth-input" placeholder="Име на изпълнителя" required>
                            </div>
                            <div class="input-details">
                                <select name="genre_id" class="custom-select" required>  
                                    <option value="" hidden disabled selected>Избери жанр</option>
                                    <% genres.forEach(genre => { %>
                                        <option value="<%= genre.id %>"><%= genre.name %></option>
                                    <% }) %>
                                </select>
                                <input type="text" name="origin" class="auth-input" placeholder="Произход (Държава/Град)">
                            </div>
                        </div>

                        <div class="dropzone-wrapper artist-dz">
                            <i data-lucide="user-plus"></i>
                            <p id="artist-file-name">Качи снимка на изпълнителя</p>
                            <input type="file" name="artist_image" accept="image/*" required
                                onchange="document.getElementById('artist-file-name').innerText = 'Избрано: ' + this.files[0].name">
                        </div>

                        <div class="action-footer">
                            <button type="submit" class="pill-btn admin-btn btn-full">Запази изпълнителя</button>
                        </div>
                    </form>
                </div>
            </section>

        </div>
    </div>

    <script>
        lucide.createIcons();

        const genreSelect = document.getElementById('genre-select');
        const subgenreSelect = document.getElementById('subgenre-select');
        const allSubOptions = Array.from(subgenreSelect.querySelectorAll('option')).filter(opt => opt.getAttribute('data-genre') !== 'none');
        const subPlaceholder = subgenreSelect.querySelector('option[data-genre="none"]');

        genreSelect.addEventListener('change', function() {
            const selectedGenreId = this.value;
            subgenreSelect.disabled = !selectedGenreId;
            subgenreSelect.innerHTML = '';
            subgenreSelect.appendChild(subPlaceholder);

            const matches = allSubOptions.filter(opt => opt.getAttribute('data-genre') == selectedGenreId);
            matches.forEach(opt => subgenreSelect.appendChild(opt));
            subgenreSelect.value = "";
        });
    </script>
</body>
</html>