<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <title>Admin Control Panel</title>
</head>
<body class="admin-page">
    <div id="container">
        <header class="home-header">
            <h1 class="admin-title">Admin Control Panel</h1>
            <div class="filter-group">
                <a href="/" class="pill-btn">← Back to Home</a>
                <a href="/logout" class="pill-btn logout-btn">Logout</a>
            </div>
        </header>

        <div class="admin-grid">
            
            <section class="admin-section main-form">
                <div class="auth-container admin-card-flat">
                    <h3 class="section-label">Add New Album</h3>
                    <form action="/admin/add-album" method="POST" enctype="multipart/form-data" class="auth-form">
                        <input type="text" name="title" class="auth-input" placeholder="Album Title" required>
                        
                        <div class="form-row">
                            <select name="artist_id" class="custom-select flex-grow" required>
                                <option value="">Select Artist</option>
                                <% artists.forEach(artist => { %>
                                    <option value="<%= artist.id %>"><%= artist.name %></option>
                                <% }) %>
                            </select>
                            <input type="number" name="release_year" class="auth-input width-small" placeholder="Year">
                        </div>

                        <div class="form-row">
                            <select name="genre_id" class="custom-select flex-1">
                                <option value="">Select Genre</option>
                                <% genres.forEach(genre => { %>
                                    <option value="<%= genre.id %>"><%= genre.name %></option>
                                <% }) %>
                            </select>
                            <select name="subgenre_id" class="custom-select flex-1">
                                <option value="">Select Subgenre</option>
                                <% subgenres.forEach(sub => { %>
                                    <option value="<%= sub.id %>"><%= sub.name %></option>
                                <% }) %>
                            </select>
                        </div>

                        <textarea name="description" class="auth-input admin-textarea" placeholder="Album Description..." rows="4"></textarea>

                        <div class="dropzone-wrapper">
                            <i data-lucide="image-plus"></i>
                            <p id="file-name">Click to upload cover</p>
                            <input type="file" name="album_image" id="album_image" accept="image/*" required 
                                   onchange="document.getElementById('file-name').innerText = 'Selected: ' + this.files[0].name">
                        </div>

                        <button type="submit" class="pill-btn admin-btn btn-full">Save Album</button>
                    </form>
                </div>
            </section>

            <aside class="admin-sidebar">
                
                <div class="auth-container admin-card-flat">
                    <h3 class="section-label">Add Artist</h3>
                    <form action="/admin/add-artist" method="POST" class="auth-form">
                        <input type="text" name="name" class="auth-input" placeholder="Artist Name" required>
                        <div class="form-row">
                            <input type="text" name="genre" class="auth-input" placeholder="Genre">
                            <input type="text" name="origin" class="auth-input" placeholder="Origin">
                        </div>
                        <button type="submit" class="pill-btn btn-full">Save Artist</button>
                    </form>
                </div>

                <div class="auth-container admin-card-flat">
                    <h3 class="section-label">Add Artist</h3>
                    <form action="/admin/add-artist" method="POST" enctype="multipart/form-data" class="auth-form">
                        <input type="text" name="name" class="auth-input" placeholder="Artist Name" required>
                        
                        <div class="form-row">
                            <input type="text" name="genre" class="auth-input flex-1" placeholder="Genre">
                            <input type="text" name="origin" class="auth-input flex-1" placeholder="Origin">
                        </div>

                        <div class="dropzone-wrapper small-dz">
                            <i data-lucide="user-plus"></i>
                            <p id="artist-file-name">Upload Artist Photo</p>
                            <input type="file" name="artist_image" accept="image/*" 
                                onchange="document.getElementById('artist-file-name').innerText = 'Selected: ' + this.files[0].name">
                        </div>

                        <button type="submit" class="pill-btn btn-full">Save Artist</button>
                    </form>
                </div>

            </aside>
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>