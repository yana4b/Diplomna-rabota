<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Music App</title>
</head>
<body>
    <nav style="display: flex; justify-content: flex-end; padding: 20px 40px; gap: 20px;">
        <% if (user) { %>
            <span>Logged in as <strong><%= user.username %></strong></span>
            <% if (user.role === 'admin') { %>
                <a href="/admin">Admin Panel</a>
            <% } %>
            <a href="/logout" style="color: #666;">Logout</a>
        <% } else { %>
            <a href="/login">Login</a>
        <% } %>
    </nav>

    <div id="container">
        <header>
            <h1>Music App</h1>
            <form action="/" method="GET" id="search-form">
                <input type="text" name="search" placeholder="Search..." value="<%= filters.search %>">
                <button type="submit" class="more-info-btn">Search</button>
            </form>
        </header>

        <main class="album-list">
            <% albums.forEach(album => { %>
                <div class="album-card">
                    
                    <% if (user && user.role === 'admin') { %>
                        <form action="/admin/delete-album" method="POST" class="admin-delete-form" onsubmit="return confirm('Delete this album?');">
                            <input type="hidden" name="album_id" value="<%= album.id %>">
                            <button type="submit" class="delete-circle-btn">✕</button>
                        </form>
                    <% } %>

                    <% if (album.album_cover) { %>
                        <img src="<%= album.album_cover %>" alt="Cover" class="album-cover">
                    <% } else { %>
                        <div class="no-cover-placeholder">No Cover</div>
                    <% } %>

                    <h2><%= album.title %></h2>
                    <p><%= album.artistName %> • <%= album.release_year %></p>
                    
                    <div style="display: flex; gap: 10px; width: 100%;">
                        <a href="/albums/<%= album.id %>" style="flex: 1; text-align: center;">More info</a>
                    </div>
                </div>
            <% }) %>
        </main>
    </div>
</body>
</html>