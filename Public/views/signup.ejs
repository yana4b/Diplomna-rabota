<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Регистрация</title>
</head>
<body class="auth-page">
    <div class="auth-wrapper">
        <div class="auth-container">
            <header class="auth-header">
                <h1>Регистрация</h1>
            </header>

            <% if (error) { %> 
                <p style="color: #ff4d4d; margin-bottom: 20px; font-size: 0.9rem;"><%= error %></p> 
            <% } %>

            <form action="/signup" method="POST" id="auth-form">
                <input type="text" name="username" class="auth-input" placeholder="Потребителско име" required>
                <input type="password" name="password" class="auth-input" placeholder="Парола" required>
                
                <button type="submit" class="pill-btn admin-btn btn-full">
                    Регистрирай се
                </button>
            </form>

            <p style="margin-top: 30px; color: #a7a7a7; font-size: 0.9rem;">
                Вече имате акаунт? 
                <a href="/login" style="color:#1DB954; text-decoration:none; font-weight:bold; margin-left: 5px;">Вход</a>
            </p>
        </div>
    </div>
</body>
</html>