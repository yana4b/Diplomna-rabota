<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title><%= song.title %> - <%= album.artistName %></title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/color-thief/2.3.0/color-thief.umd.js"></script>
</head>
<body class="song-page">
    <div id="albumContainer"> 
        <header class="album-header">
            <div class="content-wrapper">
                <div class="image-wrapper">
                    <img src="<%= album.album_cover %>" class="albumImage" crossorigin="anonymous">
                </div>
                
                <div class="header-text">
                    <p class="type-label">SONG</p>
                    <h1 class="albumTitle"><%= song.title %></h1>
                    
                    <div class="meta-data artist-info-row">
                        <% if (artist.image) { %>
                            <img src="<%= artist.image %>" class="artist-mini-img" alt="<%= artist.name %>">
                        <% } %>
                        
                        <span class="artist-link"><strong><%= artist.name %></strong></span> • 
                        <a href="/albums/<%= album.id %>" class="album-link-inline"><%= album.title %></a> • 
                        Track <%= song.track_number %>
                    </div>
                </div>
            </div>
        </header>

        <div class="content-section">
            <div class="glass-bg"></div>
            
            <div class="content-wrapper column-layout">
                <div class="song-details-box">
                    <div class="detail-item">
                        <span class="label">Duration</span>
                        <span class="value"><%= song.length || "--:--" %></span>
                    </div>
                    <div class="detail-item">
                        <span class="label">Album</span>
                        <span class="value"><%= album.title %> (<%= album.release_year %>)</span>
                    </div>
                </div>

                <div class="description-box">
                    <h3>About this track</h3>
                    <p><%= song.description || "No additional information available for this track." %></p>
                </div>

                <nav class="footer-nav">
                    <a href="/albums/<%= album.id %>" class="pill-btn">Back to Album</a>
                    <a href="/" class="pill-btn">Home</a>
                </nav>
            </div>
        </div>
    </div>

    <script>
        const img = document.querySelector('.albumImage');
        const container = document.getElementById('albumContainer');
        const colorThief = new ColorThief();

        const updateBG = () => {
            try {
                const rgb = colorThief.getColor(img);
                container.style.setProperty('--album-color', `rgb(${rgb[0]}, ${rgb[1]}, ${rgb[2]})`);
            } catch (e) { console.log(e); }
        };

        if (img.complete) updateBG();
        else img.addEventListener('load', updateBG);
    </script>
</body>
</html>