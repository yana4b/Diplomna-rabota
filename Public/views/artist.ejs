<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/styles.css">
  <title><%= artist.name %> - Albums</title>
</head>
<body>
  <div id="artistContainer">
    <h1><%= artist.name %></h1>
    <h2>Albums:</h2>

    <% if (albums.length === 0) { %>
      <p>No albums for this artist yet.</p>
    <% } else { %>
      <% albums.forEach(album => { %>
        <div class="albumDisplay">
          <img src="/images/symbolic.jpg" alt="<%= album.title %>">
          <h3><%= album.title %></h3>
          <p>Released: <%= album.release_year %></p>

          <!-- LINK to album page -->
          <a href="/albums/<%= album.id %>">More info</a>
        </div>
      <% }) %>
    <% } %>

    <a href="/">Back to Album List</a>
  </div>
</body>
</html>