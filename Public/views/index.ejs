<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Музикално приложение</title>
</head>
<body class="home-page">

    <nav class="user-controls">
        <% if (user) { %>
            <span class="user-status">Влезли сте като <strong><%= user.username %></strong></span>
            <% if (user.role === 'admin') { %>
                <a href="/admin" class="pill-btn admin-btn">Админ панел</a>
            <% } %>
            <a href="/logout" class="pill-btn logout-btn">Изход</a>
        <% } else { %>
            <a href="/login" class="pill-btn admin-btn">Вход</a>
        <% } %>
    </nav>

    <div id="container">
        <header class="home-header">
            <h1>Музикално приложение</h1>
            
            <form action="/" method="GET" id="search-form" class="main-filter-form">
                <div class="search-wrapper">
                    <input type="text" name="search" id="search-input" placeholder="Търсене..." value="<%= filters.search %>" autocomplete="off">
                    <span id="search-status" style="opacity: 0;">Търсене...</span>
                </div>

                <div class="filter-group">
                    <select name="genre" id="genre-select" class="custom-select" onchange="this.form.submit()">
                        <option value="">Всички жанрове</option>
                        <% allGenres.forEach(genre => { %>
                            <option value="<%= genre.id %>" <%= filters.genre == genre.id ? 'selected' : '' %>>
                                <%= genre.name %>
                            </option>
                        <% }) %>
                    </select>

                    <% if (subGenres && subGenres.length > 0) { %>
                        <select name="subgenre" id="subgenre-select" class="custom-select" onchange="this.form.submit()">
                            <option value="">Всички поджанрове</option>
                            <% subGenres.forEach(sub => { %>
                                <option value="<%= sub.id %>" <%= filters.subgenre == sub.id ? 'selected' : '' %>>
                                    <%= sub.name %>
                                </option>
                            <% }) %>
                        </select>
                    <% } %>
                </div>
            </form>
        </header>

        <main class="album-list">
            <% if (albums.length === 0) { %>
                <div style="grid-column: 1/-1; padding: 40px; text-align: center;">
                    <h3 style="color: #666;">Няма намерени резултати</h3>
                    <a href="/" style="color: #1DB954; text-decoration: none; font-weight: bold;">Покажи всички албуми</a>
                </div>
            <% } else { %>
                <% albums.forEach(album => { %>
                    <div class="album-card">
                        <% if (user && user.role === 'admin') { %>
                            <form action="/admin/delete-album" method="POST" class="admin-delete-form" onsubmit="return confirm('Изтриване на този албум?');">
                                <input type="hidden" name="album_id" value="<%= album.id %>">
                                <button type="submit" class="delete-circle-btn">✕</button>
                            </form>
                        <% } %>
                        <a href="/albums/<%= album.id %>">
                            <% if (album.album_cover) { %>
                                <img src="<%= album.album_cover %>" alt="Cover" class="album-cover">
                            <% } else { %>
                                <div class="no-cover-placeholder">Няма обложка</div>
                            <% } %>
                            <h2><%= album.title %></h2>
                            <p><%= album.artistName %> • <%= album.release_year %></p>
                        </a>
                    </div>
                <% }) %>
            <% } %>
        </main>
    </div>

    <script>
        const searchInput = document.getElementById('search-input');
        const searchForm = document.getElementById('search-form');
        const searchStatus = document.getElementById('search-status');
        let typingTimer;
        const doneTypingInterval = 700;

        searchInput.addEventListener('input', () => {
            clearTimeout(typingTimer);
            if (searchInput.value.trim() === '') {
                searchStatus.style.opacity = "0";
                searchForm.submit();
            } else {
                searchStatus.style.opacity = "1";
                typingTimer = setTimeout(() => {
                    searchForm.submit();
                }, doneTypingInterval);
            }
        });

        if (searchInput.value !== "") {
            searchInput.focus();
            const val = searchInput.value;
            searchInput.value = '';
            searchInput.value = val;
        }
    </script>
</body>
</html>