<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title><%= album.title %></title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/color-thief/2.3.0/color-thief.umd.js"></script>
</head>
<body class="album-page">
    <div id="albumContainer">
        <header class="album-header">
            <div class="image-wrapper">
                <img src="<%= album.album_cover %>" class="albumImage" crossorigin="anonymous">
            </div>
            <div class="header-text">
                <p class="type-label">ALBUM</p>
                <h1 class="albumTitle"><%= album.title %></h1>
                <div class="meta-data">
                    <span class="artist-link"><%= album.artistName %></span> • <%= album.release_year %> • <%= songs.length %> songs
                </div>
            </div>
        </header>

        <div class="content-section">
            <div class="glass-bg"></div>
            
            <div class="description-box">
                <p><%= album.description || "No description available." %></p>
            </div>
            
            <div class="song-table">
                <div class="list-header">
                    <span class="col-index">#</span>
                    <span class="col-title">TITLE</span>
                    <span class="col-time">DURATION</span>
                </div>

                <% songs.forEach(song => { %>
                    <div class="song-row">
                        <div class="col-index"><%= song.track_number %></div>
                        <div class="col-title">
                            <a href="/songs/<%= song.id %>" class="songTitle"><%= song.title %></a>
                        </div>
                        <div class="col-time"><%= song.length || "--:--" %></div>
                    </div>
                <% }) %>
            </div>

            <nav class="footer-nav">
                <a href="/artists/<%= album.artist_id %>" class="pill-btn">Back to Artist</a>
                <a href="/" class="pill-btn">Home</a>
            </nav>
        </div>
    </div>

    <script>
        const img = document.querySelector('.albumImage');
        const container = document.getElementById('albumContainer');
        const colorThief = new ColorThief();

        const updateBG = () => {
            const rgb = colorThief.getColor(img);
            const color = `rgb(${rgb[0]}, ${rgb[1]}, ${rgb[2]})`;
            container.style.setProperty('--album-color', color);
        };

        if (img.complete) {
            updateBG();
        } else {
            img.addEventListener('load', updateBG);
        }
    </script>
</body>
</html>