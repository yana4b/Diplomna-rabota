<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/styles.css">
  <title><%= album.title %> - Album Details</title>
</head>
<body>
  <div id="albumContainer">
  <header class="album-header">
    <div class="image-wrapper">
      <img src="/images/symbolic.jpg" alt="<%= album.title %>" class="albumImage">
    </div>
    <div class="header-text">
      <p class="eyebrow">ALBUM</p>
      <h1 class="albumTitle"><%= album.title %></h1>
      <div class="meta-data">
        <span class="artistName"><strong><%= album.artistName %></strong></span> • 
        <span class="releaseYear"><%= album.release_year %></span>
      </div>
    </div>
  </header>

  <div class="content-section">
    <p class="description"><%= album.description || "No description available." %></p>

    <div id="songsContainer">
      <div class="list-header">
        <span class="hash">#</span>
        <span>TITLE</span>
        <span class="clock">⏱</span>
      </div>
      <hr>

      <% if (songs.length === 0) { %>
        <p class="empty-msg">No songs available for this album.</p>
      <% } else { %>
        <% songs.forEach(song => { %>
          <div class="song-row">
            <p class="trackNumber"><%= song.track_number %></p>
            <div class="song-main">
               <a href="/songs/<%= song.id %>" class="songTitle"><%= song.title %></a>
            </div>
            <p class="duration"><%= song.duration %></p>
          </div>
        <% }) %>
      <% } %>
    </div>

    <nav class="footer-nav">
      <a href="/artists/<%= album.artist_id %>">Back to Artist</a>
      <a href="/">Back to Home</a>
    </nav>
  </div>
</div>
</body>
</html>