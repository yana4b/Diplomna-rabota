<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title><%= artist.name %></title>
</head>
<body class="dark-theme">

    <div id="artistPageContainer">
        <header class="artist-header" style="background-image: url('<%= artist.image %>');">
            <div class="header-overlay">
                <div class="header-content">
                    <div class="artist-details">
                        <p class="type-label">ИЗПЪЛНИТЕЛ</p>
                        <h1 class="artistNameTitle"><%= artist.name %></h1>
                        <p class="artist-meta">
                            <strong>Произход:</strong> <%= artist.origin %>
                        </p>
                    </div>
                </div>
            </div>
        </header>

        <div class="discography-section">
            <h2 class="section-title">Дискография</h2>
            
            <div class="album-list">
                <% if (albums.length > 0) { %>
                    <% albums.forEach(album => { %>
                        <a href="/albums/<%= album.id %>" class="album-card-link">
                            <div class="album-card">
                                <img src="<%= album.album_cover %>" class="album-cover" alt="<%= album.title %>">
                                
                                <div class="album-info">
                                    <h3><%= album.title %></h3>
                                    <p class="release-year"><%= album.release_year %></p>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                <% } else { %>
                    <p>Няма намерени албуми за този изпълнител.</p>
                <% } %>
            </div>

        <footer class="footer-nav">
            <a href="/" class="pill-btn logout-btn">Обратно към началото</a>
        </footer>
    </div>
</body>
</html>