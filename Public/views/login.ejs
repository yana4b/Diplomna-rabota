<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Login - Music App</title>
</head>
<body class="auth-page">
    <div id="container" class="auth-container">
        <header class="auth-header">
            <h1>Login</h1>
        </header>

        <% if (error) { %> 
            <div class="error-message"><%= error %></div> 
        <% } %>

        <form action="/login" method="POST" class="auth-form">
            <div class="input-group">
                <input type="text" name="username" placeholder="Username" required class="auth-input">
            </div>
            <div class="input-group">
                <input type="password" name="password" placeholder="Password" required class="auth-input">
            </div>
            <button type="submit" class="pill-btn admin-btn auth-submit">Sign In</button>
        </form>

        <p class="auth-footer">
            Don't have an account? <a href="/signup">Sign up here</a>
        </p>
    </div>
</body>
</html>