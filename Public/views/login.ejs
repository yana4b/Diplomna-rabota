<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Login</title>
</head>
<body>
    <div id="container" style="max-width: 400px; margin-top: 100px;">
        <header>
            <h1>Login</h1>
        </header>
        <% if (error) { %> <p style="color: #ff4d4d; margin-bottom: 10px;"><%= error %></p> <% } %>
        <form action="/login" method="POST" id="search-form" style="display: flex; flex-direction: column; gap: 15px;">
            <input type="text" name="username" placeholder="Username" required style="width: 100%;">
            <input type="password" name="password" placeholder="Password" required style="width: 100%;">
            <button type="submit" class="more-info-btn" style="border: none; cursor: pointer; width: 100%;">Sign In</button>
        </form>
        <p style="margin-top: 20px; font-size: 0.9rem;">
            Don't have an account? <a href="/signup" style="color: #1DB954; font-weight: bold; text-decoration: none;">Sign up here</a>
        </p>
    </div>
</body>
</html>